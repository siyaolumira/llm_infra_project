# llama
OLLAMA_VERSION=0.1.32
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL_SUMMARY=llama3:8b
OLLAMA_MODEL_QA=llama3:8b

# Qdrant
QDRANT_VERSION=v1.17.1
QDRANT_HOST=qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# SQLite
SQLITE_PATH=/apps/database/knowledge_base.db
COLLECTION_NAME=ollama_docker

# OpenWebUI
OPENWEBUI_VERSION=main

# Embedding
EMBEDDING_URL=http://embedding:9001
EMBED_MODEL_NAME=all-MiniLM-L6-v2
EMBED_DIM=384

# Rag
RAG_ENGINE_URL=http://rag-engine:9000

# Rerank
RERANK_MODEL_NAME=BAAI/bge-reranker-base

# Chunk
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# Safety
REQUEST_TIMEOUT=180
LLM_RETRY=3
INGEST_SLEEP=1.2